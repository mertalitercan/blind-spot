 ONLY valid JSON matching this schema:\n{\n  \"risk_score\": <int 0-100>,\n  \"confidence\": <float 0-1>,\n  \"flags\": [<string descriptive flags with numbers, e.g. \"recipient_received_4_first_time_transfers_24h\">],\n  \"reasoning\": \"<string, 2-4 sentences, be specific with numbers>\"\n}"}, {"role": "user", "content": "{\n  \"recipient_account_id\": \"pharmacy\",\n  \"recipient_graph_data\": {\n    \"account_id\": \"pharmacy\",\n    \"account_name\": \"Shoppers Drug Mart\",\n    \"incoming_transfers_24h\": 0,\n    \"unique_senders_24h\": 0,\n    \"avg_sender_account_age_days\": 900,\n    \"all_senders_first_time\": false,\n    \"recipient_account_age_days\": 4000,\n    \"flagged\": false\n  },\n  \"sender_graph_data\": {\n    \"outgoing_transfers_to_new_recipients_7d\": 0,\n    \"connection_to_flagged_accounts\": false\n  }\n}"}], "output": null, "input_tokens": null, "output_tokens": null, "total_cost": null, "system_fingerprint": null, "latency": null}], "latency": {"total_time": 0.14974689483642578}}}, "parent": {"identifier": "622f4876-bf71-4b26-91f3-93efd9ce6ef1", "node_type": "Agent", "name": "Graph Analysis Agent", "stamp": {"step": 0, "time": 1773545125.479993, "identifier": "START CREATED Graph Analysis Agent"}, "details": {"internals": {"llm_details": []}}, "parent": null}}], "status": "Failed", "edges": [{"source": null, "target": "622f4876-bf71-4b26-91f3-93efd9ce6ef1", "identifier": "c002c97c-6e1b-407f-a8d7-e654fd8c4e57", "stamp": {"step": 1, "time": 1773545125.6460469, "identifier": "Finished executing Graph Analysis Agent"}, "details": {"input_args": ["{\n  \"recipient_account_id\": \"pharmacy\",\n  \"recipient_graph_data\": {\n    \"account_id\": \"pharmacy\",\n    \"account_name\": \"Shoppers Drug Mart\",\n    \"incoming_transfers_24h\": 0,\n    \"unique_senders_24h\": 0,\n    \"avg_sender_account_age_days\": 900,\n    \"all_senders_first_time\": false,\n    \"recipient_account_age_days\": 4000,\n    \"flagged\": false\n  },\n  \"sender_graph_da